# ─── Demo mode ────────────────────────────────────────────────────────────────
# Set to "true" to use server-side keys as fallback when users don't supply theirs.
# Leave unset or "false" in production to require users to bring their own keys.
DEMO_KEYS_ENABLED=false

# Expose demo-mode flag to the client so ChatInput stays enabled.
# Must match DEMO_KEYS_ENABLED — set both or neither.
NEXT_PUBLIC_DEMO_KEYS_ENABLED=false

# ─── AI keys (only needed when DEMO_KEYS_ENABLED=true) ───────────────────────
# Fireworks.ai — get your key at https://app.fireworks.ai/settings/users/api-keys
FIREWORKS_API_KEY=fw_...

# Tavily Search — get your key at https://app.tavily.com
TAVILY_API_KEY=tvly-...

# ─── Model config (optional) ─────────────────────────────────────────────────
# Default: accounts/fireworks/models/gpt-oss-20b  ($0.07/$0.30 per 1M tokens)
# Upgrade: accounts/fireworks/models/gpt-oss-120b ($0.15/$0.60 per 1M tokens)
FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-20b

# Override Fireworks API base URL (rarely needed)
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
